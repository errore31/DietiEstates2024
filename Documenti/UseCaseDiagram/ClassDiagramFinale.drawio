        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome false\nskinparam packageStyle rectangle\n\npackage \&quot;Model\&quot; {\n    class PropertiesFeatures &lt;&lt; (M,#FFAAAA) &gt;&gt; {\n        + id : INTEGER\n        + roomCount : INTEGER\n        + area : INTEGER\n        + hasElevator : BOOLEAN\n        + floor : INTEGER\n        + energyClass : STRING\n    }\n}\n\npackage \&quot;Controller\&quot; {\n    class proprietiesFeaturesController &lt;&lt; (C,#ADD1B2) &gt;&gt; {\n        {static} + createProprietyFeatures(req, res)\n        {static} + updateProprietyFeatures(idPropertyFeature, req)\n    }\n}\n\npackage \&quot;Route\&quot; {\n    class proprietiesFeaturesRouter &lt;&lt; (R,#B2A1D1) &gt;&gt; {\n        + POST /create\n        + PUT /update/:id\n    }\n}\n\n&#39; Relazioni pulite\nproprietiesFeaturesRouter ..&gt; proprietiesFeaturesController\nproprietiesFeaturesController ..&gt; PropertiesFeatures\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="_ZRggQZsSjQUv3g1EbXC-9">
