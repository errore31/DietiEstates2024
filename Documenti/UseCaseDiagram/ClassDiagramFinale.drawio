        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome false\nskinparam packageStyle rectangle\n\npackage \&quot;Model\&quot; {\n    class Users &lt;&lt; (M,#FFAAAA) &gt;&gt; {\n        + id : INTEGER\n        + name : STRING\n        + surname : STRING\n        + username : STRING\n        + email : STRING\n        + password : STRING\n        + googleId : STRING\n        + role : STRING\n        + agencyId : INTEGER\n    }\n}\n\npackage \&quot;Controllers\&quot; {\n    class authController &lt;&lt; (C,#ADD1B2) &gt;&gt; {\n        {static} + checkCredential(req, res)\n    }\n\n    class userController &lt;&lt; (C,#ADD1B2) &gt;&gt; {\n        {static} + createUser(req, res)\n        {static} + deleteUser(idUser)\n        {static} + updateUser(idUser, req)\n        {static} + checkUsername(req, res)\n        {static} + getUser(req, res)\n        {static} + getAllAgents(agencyId)\n    }\n}\n\npackage \&quot;Routes\&quot; {\n    class authRouter &lt;&lt; (R,#B2A1D1) &gt;&gt; {\n        + POST /\n        + POST /signup\n        + GET /logout\n        + GET /google\n        + GET /google/callback\n    }\n\n    class userRouter &lt;&lt; (R,#B2A1D1) &gt;&gt; {\n        + POST /createAgent\n        + DELETE /delete/:id\n        + PUT /updateUser/:id\n        + PUT /updateAgent/:id\n        + GET /get\n        + GET /agents/:id\n    }\n}\n\n&#39; Relazioni come da immagine allegata\nauthRouter ..&gt; authController\nuserRouter ..&gt; userController\n\nauthController ..&gt; Users\nuserController ..&gt; Users\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="_ZRggQZsSjQUv3g1EbXC-12">
