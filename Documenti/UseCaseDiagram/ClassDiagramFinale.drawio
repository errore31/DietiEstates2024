        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome false\nskinparam packageStyle rectangle\n\npackage \&quot;Models\&quot; {\n    class Properties &lt;&lt; (M,#FFAAAA) &gt;&gt; {\n        + id : INTEGER\n        + title : STRING\n        + description : TEXT\n        + price : DECIMAL\n        + address : STRING\n        + type : STRING\n        + category : STRING\n        + latitude : DOUBLE\n        + longitude : DOUBLE\n        + agentId : INTEGER\n    }\n\n    class Images &lt;&lt; (M,#FFAAAA) &gt;&gt; {\n        + url : STRING\n        + order : INTEGER\n    }\n}\n\npackage \&quot;Controllers\&quot; {\n    class PropertiesController &lt;&lt; (C,#ADD1B2) &gt;&gt; {\n        {static} + createPropertyWithImage(req)\n        {static} + createProperty(req)\n        {static} + deleteProperty(idPropriety)\n        {static} + updateProperty(idPropriety, req)\n        {static} + updatePropertyFull(idPropriety, req)\n        {static} + getPropertyById(propertyId, req)\n        {static} + getSearchedProperties(propertyText, req)\n        {static} + getAdvancedSearchedProperties(req)\n        {static} + getAllProperty(req)\n        {static} + getPropertiesByAgencyId(agencyId)\n        {static} + createPromotion(propertyId, req, res)\n    }\n\n    class ImagesController &lt;&lt; (C,#ADD1B2) &gt;&gt; {\n        {static} + createImages(propertyId, files)\n        {static} + deleteImage(idImage)\n        {static} + updateImage(req, idImage)\n    }\n}\n\npackage \&quot;Routes\&quot; {\n    class PropertiesRoutes &lt;&lt; (R,#B2A1D1) &gt;&gt; {\n        + POST /create\n        + DELETE /delete/:id\n        + PUT /update/:id\n        + DELETE /images/delete/:id\n        + PUT /images/update/:id\n        + GET /search/:text\n        + GET /advanced-search\n        + GET /all\n        + GET /:id\n        + POST /:id/promotion\n    }\n}\n\n&#39; Relazioni basate sull&#39;hub delle rotte\nPropertiesRoutes ..&gt; PropertiesController\nPropertiesRoutes ..&gt; ImagesController\n\nPropertiesController --- Properties\nImagesController --- Images\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="_ZRggQZsSjQUv3g1EbXC-7">
