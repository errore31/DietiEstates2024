        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome false\nskinparam packageStyle rectangle\n\npackage \&quot;Model\&quot; {\n    class Searches &lt;&lt; (M,#FFAAAA) &gt;&gt; {\n        + id : INTEGER\n        + criteria : JSON\n        + userId : INTEGER\n    }\n}\n\npackage \&quot;Controller\&quot; {\n    class searchesController &lt;&lt; (C,#ADD1B2) &gt;&gt; {\n        {static} + createSearch(req, res)\n        {static} + deleteSearch(idSearch)\n        {static} + getSearches(req, res)\n    }\n}\n\npackage \&quot;Route\&quot; {\n    class searchesRouter &lt;&lt; (R,#B2A1D1) &gt;&gt; {\n        + POST /\n        + DELETE /delete/:id\n        + GET /history\n        + GET /suggestions\n    }\n}\n\n&#39; Relazioni pulite\nsearchesRouter ..&gt; searchesController\nsearchesController ..&gt; Searches\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="_ZRggQZsSjQUv3g1EbXC-11">
