        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome false\nskinparam packageStyle rectangle\n\npackage \&quot;Model\&quot; {\n    class RequestAgencies &lt;&lt; (M,#FFAAAA) &gt;&gt; {\n        + id : INTEGER\n        + businessName : STRING\n        + agencyName : STRING\n        + address : STRING\n        + phone : STRING\n        + email : STRING\n        + name : STRING\n        + surname : STRING\n        + username : STRING\n    }\n}\n\npackage \&quot;Controller\&quot; {\n    class requestAgencyController &lt;&lt; (C,#ADD1B2) &gt;&gt; {\n        {static} + createRequest(req)\n        {static} + getAllRequests()\n        {static} + approveRequest(id)\n        {static} + rejectRequest(id)\n    }\n}\n\npackage \&quot;Route\&quot; {\n    class requestAgencyRouter &lt;&lt; (R,#B2A1D1) &gt;&gt; {\n        + POST /\n        + GET /\n        + POST /:id/approve\n        + DELETE /:id/reject\n    }\n}\n\n&#39; Relazioni pulite\nrequestAgencyRouter ..&gt; requestAgencyController\nrequestAgencyController ..&gt; RequestAgencies\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="_ZRggQZsSjQUv3g1EbXC-10">
