        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome false\nskinparam packageStyle rectangle\n\npackage \&quot;Model\&quot; {\n    class Agencies &lt;&lt; (M,#FFAAAA) &gt;&gt; {\n        + id : INTEGER\n        + businessName : STRING\n        + name : STRING\n        + address : STRING\n        + phone : STRING\n        + email : STRING\n    }\n}\n\npackage \&quot;Controller\&quot; {\n    class agenciesController &lt;&lt; (C,#ADD1B2) &gt;&gt; {\n        {static} + createAgency(req, res)\n        {static} + deleteAgency(idAgency)\n        {static} + updateAgency(idAgency, req)\n        {static} + getAgencyById(idAgency)\n    }\n}\n\npackage \&quot;Route\&quot; {\n    class agenciesRouter &lt;&lt; (R,#B2A1D1) &gt;&gt; {\n        + POST /create\n        + DELETE /delete/:id\n        + PUT /update/:id\n        + GET /:id\n        + GET /:id/properties\n    }\n}\n\n&#39; Relazioni pulite\nagenciesRouter ..&gt; agenciesController\nagenciesController ..&gt; Agencies\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="_ZRggQZsSjQUv3g1EbXC-4">
